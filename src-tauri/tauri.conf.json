{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rosetta ERP",
  "version": "1.0.0",
  "identifier": "com.rosetta.erp",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Rosetta ERP - روزيتا المتحدة للمبيدات الزراعية",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
  "csp": null
}
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "targets": ["msi", "nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
